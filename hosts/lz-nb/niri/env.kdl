// Qt X11 scaling for 14" 2880×1800 @ 1.7x.
// QT_AUTO_SCREEN_SCALE_FACTOR tells Qt to compute scale from screen DPI:
//   - On X11: reads DPI from xsettingsd (Xft/DPI=163) → ~1.7x → WPS scales correctly
//   - On Wayland: ignored, Qt uses compositor scale → noctalia unaffected
// Unlike QT_SCALE_FACTOR, this does NOT cause double-scaling on Wayland.
environment {
    QT_AUTO_SCREEN_SCALE_FACTOR "1"
}
