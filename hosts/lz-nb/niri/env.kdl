// XWayland scaling for 14-inch 2880×1800 @ scale 1.7.
// xwayland-satellite always reports native resolution (force_unscaled),
// so X11 apps need manual DPI hints to be readable on the HiDPI panel.
environment {
    // GTK only supports integer scaling; 2 × 0.85 = 1.7
    GDK_SCALE "2"
    GDK_DPI_SCALE "0.85"
    // Qt supports fractional scaling natively
    QT_SCALE_FACTOR "1.7"
    QT_FONT_DPI "163"  // 96 × 1.7
}
